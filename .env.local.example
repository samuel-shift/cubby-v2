# ─── Auth (NextAuth v5) ────────────────────────────────────────────────────────
AUTH_SECRET=                        # Generate with: openssl rand -base64 32
AUTH_URL=http://localhost:3000

# ─── Email (Magic Link) ───────────────────────────────────────────────────────
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=              # Resend API key
EMAIL_FROM=hello@cubbyapp.com

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=                       # Supabase connection string (pooled)
DIRECT_URL=                         # Supabase direct connection (for migrations)

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI / Vision ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                  # Claude Vision for barcode/receipt/snapshot parsing

# ─── Open Food Facts ──────────────────────────────────────────────────────────
# No key needed — free public API
NEXT_PUBLIC_OFF_BASE_URL=https://world.openfoodfacts.org

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
